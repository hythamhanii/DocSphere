            "description": "Not mounted in server.js yet."
          }
        },
        {
          "name": "Get Specializations",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/specializations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "specializations"
              ]
            },
            "description": "Not mounted in server.js yet."
          }
        }
      ]
    },
    {
      "name": "04 - Doctors",
      "item": [
        {
          "name": "Create Doctor Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"Cardiologist with 10 years of experience\",\n  \"clinicAddress\": \"Cairo, Nasr City\",\n  \"consultationFee\": 500,\n  \"experienceYears\": 10\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/doctors",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "doctors"
              ]
            },
            "description": "Use Login as Doctor 1 first. specialization was removed from the default body because it must be a real MongoDB ObjectId if provided."
          }
        },
        {
          "name": "Get All Doctors",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/doctors",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "doctors"
              ]
            }
          }
        },
        {
          "name": "Get Doctor By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/doctors/{{doctorId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "doctors",
                "{{doctorId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "05 - Services",
      "description": "These routes exist in the codebase, but they are not mounted in server.js yet. They will work only after you mount the routes in the Express app.",
      "item": [
        {
          "name": "Create Service",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctor\": \"{{doctorId}}\",\n  \"name\": \"General Consultation\",\n  \"description\": \"Doctor consultation and diagnosis\",\n  \"price\": 500,\n  \"duration\": 30\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/services",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "services"
              ]
            },
            "description": "Use Login as Doctor 1 first. Not mounted in server.js yet."
          }
        },
        {
          "name": "Get Services",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/services",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "services"
              ]
            },
            "description": "Not mounted in server.js yet."
          }
        },
        {
          "name": "Delete Service",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/services/{{serviceDeleteId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "services",
                "{{serviceDeleteId}}"
              ]
            },
            "description": "Use a real service id in {{serviceDeleteId}}. Not mounted in server.js yet."
          }
        }
      ]
    },
    {
      "name": "06 - Appointments",
      "item": [
        {
          "name": "Create Appointment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctor\": \"{{doctorId}}\",\n  \"appointmentDate\": \"2026-03-30T10:00:00.000Z\",\n  \"notes\": \"First consultation\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/appointments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "appointments"
              ]
            },
            "description": "Use Login as Patient 1 first. service was removed from the default body because it must be a real MongoDB ObjectId if provided."
          }
        },
        {
          "name": "Get My Appointments",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/appointments/my",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "appointments",
                "my"
              ]
            },
            "description": "Use Login as Patient 1 first."
          }
        },
        {
          "name": "Update Appointment Status",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"confirmed\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/appointments/{{appointmentId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "appointments",
                "{{appointmentId}}",
                "status"
              ]
            },
            "description": "Allowed status values: pending, confirmed, cancelled, completed."
          }
        }
      ]
    },
    {
      "name": "07 - Payments",
      "item": [
        {
          "name": "Create Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
