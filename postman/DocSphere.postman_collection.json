{
  "info": {
    "_postman_id": "b5a1d5f0-3e19-4b4c-a7ec-6c5d2c7f1a01",
    "name": "DocSphere Backend",
    "description": "Postman collection for testing the DocSphere backend with seeded sample accounts and IDs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "doctorId",
      "value": ""
    },
    {
      "key": "appointmentId",
      "value": ""
    },
    {
      "key": "specializationId",
      "value": ""
    },
    {
      "key": "serviceId",
      "value": ""
    },
    {
      "key": "serviceDeleteId",
      "value": ""
    },
    {
      "key": "patientEmail",
      "value": "patient1@docsphere.com"
    },
    {
      "key": "doctorEmail",
      "value": "doctor1@docsphere.com"
    },
    {
      "key": "adminEmail",
      "value": "admin1@docsphere.com"
    },
    {
      "key": "defaultPassword",
      "value": "123456"
    }
  ],
  "item": [
    {
      "name": "00 - Quick Start",
      "description": "Recommended order: 1) run node seed.js, 2) login as doctor/admin/patient using the requests below, 3) paste IDs from seed output into collection variables, 4) test all endpoints.",
      "item": [
        {
          "name": "Swagger Docs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/docs",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "docs"
              ]
            },
            "description": "Open Swagger UI documentation."
          }
        }
      ]
    },
    {
      "name": "01 - Seeded Logins",
      "description": "These are the easiest login requests to use after running node seed.js.",
      "item": [
        {
          "name": "Login as Doctor 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const jsonData = pm.response.json();",
                  "if (jsonData.token) pm.collectionVariables.set('token', jsonData.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{doctorEmail}}\",\n  \"password\": \"{{defaultPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Logs in doctor1@docsphere.com and saves token to {{token}}."
          }
        },
        {
          "name": "Login as Patient 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const jsonData = pm.response.json();",
                  "if (jsonData.token) pm.collectionVariables.set('token', jsonData.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{patientEmail}}\",\n  \"password\": \"{{defaultPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Logs in patient1@docsphere.com and saves token to {{token}}."
          }
        },
        {
          "name": "Login as Admin 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const jsonData = pm.response.json();",
                  "if (jsonData.token) pm.collectionVariables.set('token', jsonData.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{defaultPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Logs in admin1@docsphere.com and saves token to {{token}}."
          }
        }
      ]
    },
    {
      "name": "02 - Auth",
      "item": [
        {
          "name": "Register Patient",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Ali\",\n  \"lastName\": \"Hassan\",\n  \"email\": \"patient@example.com\",\n  \"password\": \"123456\",\n  \"role\": \"patient\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Register Doctor",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Sara\",\n  \"lastName\": \"Mahmoud\",\n  \"email\": \"doctor@example.com\",\n  \"password\": \"123456\",\n  \"role\": \"doctor\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Admin\",\n  \"lastName\": \"User\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"123456\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const jsonData = pm.response.json();",
                  "if (jsonData.token) pm.collectionVariables.set('token', jsonData.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"patient@example.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Generic login request. Saves returned token to {{token}}."
          }
        }
      ]
    },
    {
      "name": "03 - Specializations",
      "description": "These routes exist in the codebase, but they are not mounted in server.js yet. They will work only after you mount the routes in the Express app.",
      "item": [
        {
          "name": "Create Specialization",
          "request": {
            "method": "POST",
            "header": [
              {
