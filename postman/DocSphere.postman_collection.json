            "body": {
              "mode": "raw",
              "raw": "{\n  \"appointment\": \"{{appointmentId}}\",\n  \"amount\": 500,\n  \"method\": \"cash\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/payments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
