              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Neurology\",\n  \"description\": \"Brain and nervous system care\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/specializations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
